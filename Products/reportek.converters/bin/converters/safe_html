#!/usr/bin/env python
# -*- coding: utf-8 -*-
import argparse
import sys

import bleach
from bleach.css_sanitizer import CSSSanitizer
from bs4 import BeautifulSoup as bs


ALLOWED_TAGS = [
    "a", "abbr", "acronym", "b", "blockquote", "br", "cite", "code",
    "dd", "del", "dfn", "div", "dl", "dt", "em", "h1", "h2", "h3",
    "h4", "h5", "h6", "hr", "i", "img", "ins", "kbd", "li", "ol",
    "p", "pre", "q", "s", "samp", "span", "strike", "strong", "sub",
    "sup", "table", "tbody", "td", "tfoot", "th", "thead", "tr", "tt",
    "ul", "var",
]

ALLOWED_ATTRIBUTES = [
    "abbr", "alt", "cite", "class", "colspan", "datetime", "height",
    "href", "i18n:translate", "id", "name", "rel", "rowspan", "src",
    "style", "title", "width",
]

ALLOWED_PROTOCOLS = ["http", "https", "mailto"]


def scrub(html):
    """Sanitize HTML while preserving Reportek feedback markup."""
    soup = bs(html, features="lxml")
    for node in soup(["script", "style"]):
        node.decompose()

    cleaned = bleach.clean(
        str(soup),
        tags=ALLOWED_TAGS,
        attributes=ALLOWED_ATTRIBUTES,
        protocols=ALLOWED_PROTOCOLS,
        css_sanitizer=CSSSanitizer(),
        strip=True,
        strip_comments=True,
    )
    return bs(cleaned, features="lxml")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="HTML sanitizer")
    parser.add_argument("src_file", metavar="src-file", help="path to html file")
    params = parser.parse_args()
    with open(params.src_file, "rb") as src_file:
        sys.stdout.write(scrub(src_file.read()).prettify())
